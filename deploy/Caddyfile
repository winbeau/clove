# Caddyfile for Clove on this VPS.
#
# Why :8443 and DNS-01:
#   - port 443 is held by Xray REALITY on this host, can't share.
#   - We listen on :8443 and let Caddy fetch its own Let's Encrypt cert via
#     DNS-01 against Tencent Cloud DNSPod (caddy-dns/tencentcloud plugin).
#     Need a Tencent Cloud API key (SecretId + SecretKey) loaded from
#     /etc/caddy/secrets.env via the systemd unit.
#
# Reload after editing: `sudo systemctl reload caddy`.

{
    # No port 80 redirect — Xray doesn't conflict because Xray uses :443,
    # but we explicitly disable the HTTP-side automatic redirect anyway
    # since this host doesn't expose :80 publicly.
    auto_https disable_redirects
    admin off
}

claude.selab.top:8443 {
    tls {
        dns tencentcloud {
            secret_id {env.TENCENTCLOUD_SECRET_ID}
            secret_key {env.TENCENTCLOUD_SECRET_KEY}
        }
    }

    encode zstd gzip

    # Anthropic streaming responses are SSE — disable buffering and bump
    # idle timeouts so long generations don't get cut.
    reverse_proxy 127.0.0.1:5201 {
        flush_interval -1
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }

    log {
        output stderr
        format console
    }
}
