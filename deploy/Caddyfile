# Caddyfile for Clove on this VPS.
#
# Why :8443 and a static cert:
#   - port 443 on this host is occupied by Xray (REALITY), can't share
#   - Let's Encrypt cert is issued out-of-band by acme.sh via DNS-01 (DNSPod),
#     installed at /home/winbeau/clove/deploy/certs/, and renewed by the
#     acme.sh cron with --reloadcmd hooking back into Caddy
#
# Reload after editing: `systemctl --user reload caddy` or
# `sudo systemctl reload caddy` depending on how the unit is installed.

{
    # Don't try to fight Xray for 80/443. We do TLS ourselves on 8443 with
    # the externally-issued cert; no automatic ACME, no HTTP redirect.
    auto_https off
    admin off
}

claude.selab.top:8443 {
    tls /home/winbeau/clove/deploy/certs/claude.selab.top.crt /home/winbeau/clove/deploy/certs/claude.selab.top.key

    encode zstd gzip

    # Anthropic streaming responses are SSE — disable buffering and bump
    # idle timeouts so long generations don't get cut.
    reverse_proxy 127.0.0.1:5201 {
        flush_interval -1
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }

    log {
        output stderr
        format console
    }
}
